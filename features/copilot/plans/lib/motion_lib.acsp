// file: features/copilot/plans/lib/motion_lib.acsp
// 简易运动库（更接近真实 ACSpl+ 风格）
// 请将函数名与控制器 API 对照替换为你所在站点的真实命令

// 获取当前时间（毫秒）
FUNCTION CURRENT_TIME_MS()
  // 伪实现—请使用控制器提供的时间函数
  RETURN GET_SYSTEM_TIME_MS()
ENDFUNCTION

// 等待轴到位的辅助函数
FUNCTION WaitForDone(axis, timeout_ms)
  VAR start := CURRENT_TIME_MS()
  WHILE TRUE DO
    IF AxisIsInAlarm(axis) THEN
      LOG(ERROR, 'Axis ' + axis + ' alarm detected')
      RETURN FALSE
    ENDIF
    IF AxisAtTarget(axis) THEN
      RETURN TRUE
    ENDIF
    IF CURRENT_TIME_MS() - start > timeout_ms THEN
      LOG(WARN, 'Timeout waiting for axis ' + axis)
      RETURN FALSE
    ENDIF
    WAIT_MS(50)
  ENDWHILE
ENDFUNCTION

// 绝对移动
FUNCTION MoveAbs(axis, target_pos, speed)
  IF NOT IsAxisConfigured(axis) THEN
    LOG(ERROR, 'MoveAbs: axis ' + axis + ' not configured')
    RETURN FALSE
  ENDIF

  // 设置速度并发起移动
  SET_VELOCITY(axis, speed)
  MOVE_ABSOLUTE(axis, target_pos)

  VAR ok := WaitForDone(axis, 5000)
  IF NOT ok THEN
    LOG(ERROR, 'MoveAbs failed for ' + axis + ' to ' + TO_STRING(target_pos))
    RETURN FALSE
  ENDIF
  RETURN TRUE
ENDFUNCTION

// 相对移动
FUNCTION MoveRel(axis, delta, speed)
  VAR current := GetAxisPosition(axis)
  VAR target := current + delta
  RETURN MoveAbs(axis, target, speed)
ENDFUNCTION

// 示例入口
FUNCTION DemoMoves()
  LOG(INFO, 'DemoMoves start')
  IF MoveAbs('AXIS1', 1000, 60) THEN
    LOG(INFO, 'AXIS1 moved to 1000')
  ELSE
    LOG(ERROR, 'AXIS1 move failed')
  ENDIF

  IF MoveRel('AXIS1', -200, 40) THEN
    LOG(INFO, 'AXIS1 returned by -200')
  ELSE
    LOG(ERROR, 'AXIS1 relative move failed')
  ENDIF
  LOG(INFO, 'DemoMoves complete')
ENDFUNCTION

// 仅在脚本被直接执行时运行演示
IF SCRIPT_RUNNING_AS_MAIN() THEN
  DemoMoves()
ENDIF
